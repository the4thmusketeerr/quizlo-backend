generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Model
model User {
  id         String   @id @default(uuid())
  first_name String
  last_name  String
  username   String   @unique
  email      String   @unique
  password   String
  createdAt  DateTime @default(now())
}